{

    // ==========================================
    // AJUSTES GENERALES DEL ESPACIO DE TRABAJO (VS CODE)
    // ==========================================

    // Dibuja la línea de guía vertical en la columna 80

    "[python]": {
        "editor.tabSize": 2,
        "editor.insertSpaces": true,
        "editor.indentSize": "tabSize",
        //"editor.formatOnSave": true,
        "editor.rulers": [80],
        "editor.wordWrap": "wordWrapColumn",
        "editor.wordWrapColumn": 80
    },

    "[markdown]": {
        "editor.wordWrap": "wordWrapColumn",
        "editor.wordWrapColumn": 80,
        "editor.rulers": [80],
    }
}